# No environment variables are required to run or build this portfolio.
# This file documents optional configuration for future integrations.

# If you later swap the contact form to a third-party service (Formspree,
# Resend, etc.), put its key here and read it in the form handler.
# NEXT_PUBLIC_FORM_ENDPOINT=

# Netlify skew protection (optional; see Netlify Next.js docs).
# NETLIFY_NEXT_SKEW_PROTECTION=true
